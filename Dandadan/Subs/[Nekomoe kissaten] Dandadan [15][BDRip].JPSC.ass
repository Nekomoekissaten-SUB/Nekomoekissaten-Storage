Comment: 0,0:06:28.03,0:06:28.08,Default,,0,0,0,,OP
Dialogue: 0,0:06:28.24,0:06:29.62,OP_JP,,0,0,0,,唸るぜ
Dialogue: 0,0:06:29.62,0:06:34.46,OP_JP,,0,0,0,,血泥ついたって守りたい
Dialogue: 0,0:06:34.71,0:06:39.21,OP_JP,,0,0,0,,革命道中だって君に夢中
Dialogue: 0,0:06:39.21,0:06:44.97,OP_JP,,0,0,0,,暗闇染み込む世界で見つけた
Dialogue: 0,0:06:44.97,0:06:48.01,OP_JP,,0,0,0,,センチメンタルな恋
Dialogue: 0,0:06:57.94,0:07:01.57,OP_JP,,0,0,0,,{\blur10\3a&HA0&\bord1}甘くぬかるんだ眼差し
Dialogue: 0,0:07:03.11,0:07:06.74,OP_JP,,0,550,0,,変に色気あるから困った
Dialogue: 0,0:07:08.32,0:07:11.95,OP_JP,,0,0,0,,手を繋ぐ勇気出したくて
Dialogue: 0,0:07:13.33,0:07:18.58,OP_JP,,0,0,0,,{\t(4526,5194,0.1,\alpha&HFF&)}身の程わきまえてちゃ出来ないね
Dialogue: 0,0:07:17.79,0:07:20.59,OP_JP,,0,0,0,,{\alpha&HFF&\t(0,684,3,\alpha&H00&)}暗いトンネルの壁
Dialogue: 0,0:07:20.59,0:07:23.55,OP_JP,,0,0,0,,したたり落ちる秘密
Dialogue: 0,0:07:23.92,0:07:28.47,OP_JP,,0,0,0,,{\1a&HFF&\3a&HC0&\bord1\blur10}しめやかに高鳴る心
Dialogue: 1,0:07:23.92,0:07:28.47,OP_JP,,0,0,0,,{\yshad1}しめやかに高鳴る心
Dialogue: 0,0:07:29.34,0:07:30.18,OP_JP,,0,0,0,,{\yshad1}ダメ　ダメ
Dialogue: 0,0:07:30.60,0:07:31.39,OP_JP,,0,0,0,,{\yshad1}待て　待て
Dialogue: 0,0:07:31.76,0:07:33.77,OP_JP,,0,0,0,,{\yshad1\t(851,1101,\4a&HC0&)}呪いも病も抱きしめたい
Dialogue: 0,0:07:33.93,0:07:37.23,OP_JP,,0,0,0,,ここらで暴れちゃってもいいかな
Dialogue: 0,0:07:37.23,0:07:39.19,OP_JP,,0,0,0,,ああ　唸るぜ
Dialogue: 0,0:07:39.19,0:07:44.19,OP_JP,,0,0,0,,血泥ついたって守りたい
Dialogue: 0,0:07:44.19,0:07:48.86,OP_JP,,0,0,0,,革命道中だって　君に夢中
Dialogue: 0,0:07:48.86,0:07:54.58,OP_JP,,0,0,0,,暗闇染み込む世界で見つけた
Dialogue: 0,0:07:54.58,0:07:57.25,OP_JP,,0,0,0,,センチメンタルな恋
Dialogue: 0,0:06:28.24,0:06:29.62,OP_CH,,0,0,0,,我要呻吟
Dialogue: 0,0:06:29.62,0:06:34.46,OP_CH,,0,0,0,,即便染血沾泥  也要守护你
Dialogue: 0,0:06:34.71,0:06:39.21,OP_CH,,0,0,0,,身处革命途中  仍为你倾心
Dialogue: 0,0:06:39.21,0:06:44.97,OP_CH,,0,0,0,,于灰暗世界中寻得光影
Dialogue: 0,0:06:44.97,0:06:48.01,OP_CH,,0,0,0,,一段热烈的恋情
Dialogue: 0,0:06:57.94,0:07:01.57,OP_CH,,0,0,0,,{\blur10\3a&HA0&\bord1}你眼神迷离  我躲闪不及
Dialogue: 0,0:07:03.11,0:07:06.74,OP_CH,,0,550,0,,妩媚身形  让人无法自已
Dialogue: 0,0:07:08.32,0:07:11.95,OP_CH,,0,0,0,,想鼓起勇气  将那手牵起
Dialogue: 0,0:07:13.33,0:07:18.58,OP_CH,,0,0,0,,{\t(4526,5194,0.1,\alpha&HFF&)}却又突然清醒  无力靠近
Dialogue: 0,0:07:17.79,0:07:20.59,OP_CH,,0,0,0,,{\alpha&HFF&\t(0,684,3,\alpha&H00&)\c&H47D6F7&}阴暗隧道的墙壁
Dialogue: 0,0:07:20.59,0:07:23.55,OP_CH,,0,0,0,,{\c&H47D6F7&}滴落着无人知晓的秘密
Dialogue: 0,0:07:23.92,0:07:28.47,OP_CH,,0,0,0,,{\1a&HFF&\3a&HC0&\bord1\blur10}寂静中心跳愈发激烈
Dialogue: 1,0:07:23.92,0:07:28.47,OP_CH,,0,0,0,,{\yshad1}寂静中心跳愈发激烈
Dialogue: 0,0:07:29.34,0:07:30.18,OP_CH,,0,0,0,,{\yshad1}不行  不行
Dialogue: 0,0:07:30.60,0:07:31.39,OP_CH,,0,0,0,,{\yshad1}等等  等等
Dialogue: 0,0:07:31.76,0:07:33.77,OP_CH,,0,0,0,,{\yshad1\t(851,1101,\4a&HC0&)}连诅咒与病痛也想一起拥紧
Dialogue: 0,0:07:33.93,0:07:37.23,OP_CH,,0,0,0,,此刻若放肆一次  是否也无妨
Dialogue: 0,0:07:37.23,0:07:39.19,OP_CH,,0,0,0,,我要呻吟
Dialogue: 0,0:07:39.19,0:07:44.19,OP_CH,,0,0,0,,即便染血沾泥  也要守护你
Dialogue: 0,0:07:44.19,0:07:48.86,OP_CH,,0,0,0,,身处革命途中  仍为你倾心
Dialogue: 0,0:07:48.86,0:07:54.58,OP_CH,,0,0,0,,于灰暗世界中寻得光影
Dialogue: 0,0:07:54.58,0:07:57.25,OP_CH,,0,0,0,,一段热烈的恋情
Comment: 0,0:22:13.02,0:22:13.06,Default,,0,0,0,,ED
Dialogue: 0,0:22:14.61,0:22:15.40,ED_JP,,0,0,0,,Damn
Dialogue: 0,0:22:27.20,0:22:29.58,ED_JP,,0,0,0,,ねえ　今どう思ってる
Dialogue: 0,0:22:29.58,0:22:31.29,ED_JP,,0,0,0,,君が気になり出し
Dialogue: 0,0:22:31.29,0:22:32.83,ED_JP,,0,0,0,,気功砲で
Dialogue: 0,0:22:33.25,0:22:35.67,ED_JP,,0,0,0,,ねえ　今どう感じてる
Dialogue: 0,0:22:35.67,0:22:37.38,ED_JP,,0,0,0,,バイトほったらかし
Dialogue: 0,0:22:37.38,0:22:38.84,ED_JP,,0,0,0,,想いを撃て
Dialogue: 0,0:22:39.25,0:22:40.38,ED_JP,,0,0,0,,よく泣いて
Dialogue: 0,0:22:40.38,0:22:42.30,ED_JP,,0,0,0,,よく食べているのに
Dialogue: 0,0:22:42.30,0:22:43.43,ED_JP,,0,0,0,,ちょっと待って
Dialogue: 0,0:22:43.43,0:22:45.30,ED_JP,,0,0,0,,ちょうど空いているのに
Dialogue: 0,0:22:45.30,0:22:46.39,ED_JP,,0,0,0,,よく泣いて
Dialogue: 0,0:22:46.39,0:22:48.22,ED_JP,,0,0,0,,よく食べているのに
Dialogue: 0,0:22:48.22,0:22:49.47,ED_JP,,0,0,0,,用もないし
Dialogue: 0,0:22:49.47,0:22:50.47,ED_JP,,0,0,0,,どうかしてる
Dialogue: 0,0:22:51.39,0:22:53.85,ED_JP,,0,0,0,,どうかしてるのに
Dialogue: 0,0:22:53.85,0:22:55.98,ED_JP,,0,0,0,,会いたい　でもこじらせ
Dialogue: 0,0:22:55.98,0:22:57.15,ED_JP,,0,0,0,,どうかしてる
Dialogue: 0,0:22:57.40,0:22:59.98,ED_JP,,0,0,0,,どうかしてるのに
Dialogue: 0,0:22:59.98,0:23:02.03,ED_JP,,0,0,0,,慣れないまま君と出会い
Dialogue: 0,0:23:02.03,0:23:03.15,ED_JP,,0,0,0,,どうかしてる
Dialogue: 0,0:23:03.57,0:23:06.37,ED_JP,,0,0,0,,未開拓　真相に迫りたい
Dialogue: 0,0:23:06.78,0:23:09.24,ED_JP,,0,0,0,,未開拓　真実を手にしたい
Dialogue: 0,0:23:09.66,0:23:12.12,ED_JP,,0,0,0,,どうかしてるのに
Dialogue: 0,0:23:12.12,0:23:14.21,ED_JP,,0,0,0,,慣れないまま君と出会い
Dialogue: 0,0:23:14.21,0:23:15.83,ED_JP,,0,0,0,,どうかしてる
Dialogue: 0,0:23:15.83,0:23:18.21,ED_JP,,0,0,0,,どうかしてるのに
Dialogue: 0,0:23:18.21,0:23:21.76,ED_JP,,0,0,0,,会いたい　でもこじらせどうかしてる
Dialogue: 0,0:23:21.76,0:23:24.26,ED_JP,,0,0,0,,どうかしてるのに
Dialogue: 0,0:23:24.26,0:23:26.34,ED_JP,,0,0,0,,慣れないまま君と出会い
Dialogue: 0,0:23:26.34,0:23:27.59,ED_JP,,0,0,0,,どうかしてる
Dialogue: 0,0:23:28.10,0:23:31.14,ED_JP,,0,0,0,,未開拓　真相に迫りたい
Dialogue: 0,0:23:31.14,0:23:33.85,ED_JP,,0,0,0,,未開拓　真実を手にしたい
Dialogue: 0,0:23:34.14,0:23:36.40,ED_JP,,0,0,0,,どうかしてるのに
Dialogue: 0,0:23:36.40,0:23:38.48,ED_JP,,0,0,0,,闘い　出会い　嫌い　愛
Dialogue: 0,0:23:38.48,0:23:40.57,ED_JP,,0,0,0,,どうかしてるよ
Dialogue: 0,0:22:27.20,0:22:29.58,ED_CH_SC,,0,0,0,,嘿 你现在在想什么
Dialogue: 0,0:22:29.58,0:22:31.29,ED_CH_SC,,0,0,0,,我开始在意起你
Dialogue: 0,0:22:31.29,0:22:32.83,ED_CH_SC,,0,0,0,,比起气功炮的手势
Dialogue: 0,0:22:33.25,0:22:35.67,ED_CH_SC,,0,0,0,,嘿 你此刻什么感觉
Dialogue: 0,0:22:35.67,0:22:37.38,ED_CH_SC,,0,0,0,,把兼职抛诸脑后
Dialogue: 0,0:22:37.38,0:22:38.84,ED_CH_SC,,0,0,0,,将思念朝你发射
Dialogue: 0,0:22:39.25,0:22:40.38,ED_CH_SC,,0,0,0,,明明没少哭
Dialogue: 0,0:22:40.38,0:22:42.30,ED_CH_SC,,0,0,0,,也有好好吃饭
Dialogue: 0,0:22:42.30,0:22:43.43,ED_CH_SC,,0,0,0,,为什么不等我
Dialogue: 0,0:22:43.43,0:22:45.30,ED_CH_SC,,0,0,0,,你不是正好有空吗
Dialogue: 0,0:22:45.30,0:22:46.39,ED_CH_SC,,0,0,0,,明明没少哭
Dialogue: 0,0:22:46.39,0:22:48.22,ED_CH_SC,,0,0,0,,也有好好吃饭
Dialogue: 0,0:22:48.22,0:22:49.47,ED_CH_SC,,0,0,0,,明明找你也没事
Dialogue: 0,0:22:49.47,0:22:50.47,ED_CH_SC,,0,0,0,,我怎么会这样
Dialogue: 0,0:22:51.39,0:22:53.85,ED_CH_SC,,0,0,0,,明明知道自己不正常
Dialogue: 0,0:22:53.85,0:22:55.98,ED_CH_SC,,0,0,0,,想要见你 却又自己搞砸
Dialogue: 0,0:22:55.98,0:22:57.15,ED_CH_SC,,0,0,0,,我怎么会这样
Dialogue: 0,0:22:57.40,0:22:59.98,ED_CH_SC,,0,0,0,,明明知道自己不正常
Dialogue: 0,0:22:59.98,0:23:02.03,ED_CH_SC,,0,0,0,,却毫无准备就见到你
Dialogue: 0,0:23:02.03,0:23:03.15,ED_CH_SC,,0,0,0,,我怎么会这样
Dialogue: 0,0:23:03.57,0:23:06.37,ED_CH_SC,,0,0,0,,未知领域 我想探个究竟
Dialogue: 0,0:23:06.78,0:23:09.24,ED_CH_SC,,0,0,0,,未知领域 我想抓住真心
Dialogue: 0,0:23:09.66,0:23:12.12,ED_CH_SC,,0,0,0,,明明知道自己不正常
Dialogue: 0,0:23:12.12,0:23:14.21,ED_CH_SC,,0,0,0,,却毫无准备就见到你
Dialogue: 0,0:23:14.21,0:23:15.83,ED_CH_SC,,0,0,0,,我怎么会这样
Dialogue: 0,0:23:15.83,0:23:18.21,ED_CH_SC,,0,0,0,,明明知道自己不正常
Dialogue: 0,0:23:18.21,0:23:21.76,ED_CH_SC,,0,0,0,,想要见你 却又自己搞砸
Dialogue: 0,0:23:21.76,0:23:24.26,ED_CH_SC,,0,0,0,,明明知道自己不正常
Dialogue: 0,0:23:24.26,0:23:26.34,ED_CH_SC,,0,0,0,,却毫无准备就见到你
Dialogue: 0,0:23:26.34,0:23:27.59,ED_CH_SC,,0,0,0,,我怎么会这样
Dialogue: 0,0:23:28.10,0:23:31.14,ED_CH_SC,,0,0,0,,未知领域 我想探个究竟
Dialogue: 0,0:23:31.14,0:23:33.85,ED_CH_SC,,0,0,0,,未知领域 我想抓住真心
Dialogue: 0,0:23:34.14,0:23:36.40,ED_CH_SC,,0,0,0,,明明知道自己不正常
Dialogue: 0,0:23:36.40,0:23:38.48,ED_CH_SC,,0,0,0,,争斗 邂逅 厌恶 恋爱
Dialogue: 0,0:23:38.48,0:23:40.57,ED_CH_SC,,0,0,0,,我一定是疯了
